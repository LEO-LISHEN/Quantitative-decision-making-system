# Shared API configuration
APP_HOST=127.0.0.1
APP_PORT=8010
DEEPSEEK_API_KEY=
DEEPSEEK_API_BASE=https://api.deepseek.com/chat/completions

# Event Focus
EVENT_FOCUS_MODEL=deepseek-chat
EVENT_FOCUS_CACHE_SECONDS=1800
EVENT_FOCUS_MAX_SOURCE_ITEMS=18
EVENT_FOCUS_MAX_CARDS=6
EVENT_FOCUS_A_SHARE_URLS=
EVENT_FOCUS_HK_SHARE_URLS=
EVENT_FOCUS_US_SHARE_URLS=

# PostgreSQL / quant-db
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=15432
POSTGRES_DB=quant
POSTGRES_USER=quant
POSTGRES_PASSWORD=quant_dev_password

# Enterprise WeChat robot. Leave empty to use simulated notifications.
WECOM_WEBHOOK_URL=
DEMO_CHAT_MODEL=deepseek-chat
DATA_SOURCE_MODE=tushare_direct
TUSHARE_TOKEN=

# Financial Analyst Skills may also read its own .env file.
# Do not commit real .env files.
